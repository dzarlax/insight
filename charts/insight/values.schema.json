{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Insight umbrella values",
  "description": "Minimal schema. Validates the unified per-dependency shape (deploy + flat host/port/passwordSecret) and enforces image.tag is set on every app service.",
  "type": "object",
  "properties": {
    "credentials": {
      "type": "object",
      "properties": {
        "deploymentMode": { "enum": ["helm", "gitops"] },
        "autoGenerate":   { "type": "boolean" }
      }
    },

    "ingestion": {
      "type": "object",
      "properties": {
        "templates": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "toolboxImage":    { "type": "string" },
        "jiraEnrichImage": { "type": "string" },
        "freshness": {
          "type": "object",
          "properties": {
            "enabled":               { "type": "boolean" },
            "schedule":              { "type": "string" },
            "dbtSelect":             { "type": "string" },
            "cluster":               { "type": "string" },
            "tenant":                { "type": "string" },
            "notification": {
              "type": "object",
              "properties": {
                "driver": { "type": "string", "enum": ["", "webhook", "zulip", "slack", "teams", "email"] },
                "webhook": {
                  "type": "object",
                  "properties": {
                    "urlSecret": { "$ref": "#/definitions/urlSecret" }
                  }
                },
                "zulip": {
                  "type": "object",
                  "properties": {
                    "urlSecret": { "$ref": "#/definitions/urlSecret" },
                    "stream":    { "type": "string" },
                    "topic":     { "type": "string" }
                  }
                },
                "slack": {
                  "type": "object",
                  "properties": {
                    "urlSecret": { "$ref": "#/definitions/urlSecret" },
                    "channel":   { "type": "string" }
                  }
                },
                "teams": {
                  "type": "object",
                  "properties": {
                    "urlSecret": { "$ref": "#/definitions/urlSecret" }
                  }
                },
                "email": {
                  "type": "object",
                  "properties": {
                    "smtp": {
                      "type": "object",
                      "properties": {
                        "host":     { "type": "string" },
                        "port":     { "type": "integer", "minimum": 1, "maximum": 65535 },
                        "username": { "type": "string" },
                        "passwordSecret": { "$ref": "#/definitions/urlSecret" },
                        "starttls": { "type": "boolean" }
                      }
                    },
                    "from":          { "type": "string" },
                    "to":            { "type": "string" },
                    "subjectPrefix": { "type": "string" }
                  }
                }
              },
              "allOf": [
                {
                  "if":   { "properties": { "driver": { "const": "webhook" } }, "required": ["driver"] },
                  "then": { "properties": { "webhook": { "$ref": "#/definitions/urlSecretBlock" } }, "required": ["webhook"] }
                },
                {
                  "if":   { "properties": { "driver": { "const": "zulip" } }, "required": ["driver"] },
                  "then": { "properties": { "zulip": { "$ref": "#/definitions/urlSecretBlock" } }, "required": ["zulip"] }
                },
                {
                  "if":   { "properties": { "driver": { "const": "slack" } }, "required": ["driver"] },
                  "then": { "properties": { "slack": { "$ref": "#/definitions/urlSecretBlock" } }, "required": ["slack"] }
                },
                {
                  "if":   { "properties": { "driver": { "const": "teams" } }, "required": ["driver"] },
                  "then": { "properties": { "teams": { "$ref": "#/definitions/urlSecretBlock" } }, "required": ["teams"] }
                },
                {
                  "if":   { "properties": { "driver": { "const": "email" } }, "required": ["driver"] },
                  "then": {
                    "properties": {
                      "email": {
                        "type": "object",
                        "required": ["smtp", "from", "to"],
                        "properties": {
                          "smtp": {
                            "type": "object",
                            "required": ["host"],
                            "properties": {
                              "host": { "type": "string", "minLength": 1 },
                              "from": { "type": "string", "minLength": 1 },
                              "to":   { "type": "string", "minLength": 1 }
                            }
                          },
                          "from": { "type": "string", "minLength": 1 },
                          "to":   { "type": "string", "minLength": 1 }
                        }
                      }
                    },
                    "required": ["email"]
                  }
                }
              ]
            },
            "thresholds": {
              "type": "object",
              "properties": {
                "defaultWarnHours":          { "type": "integer", "minimum": 1 },
                "defaultErrorHours":         { "type": "integer", "minimum": 1 },
                "eventWarnHours":            { "type": "integer", "minimum": 1 },
                "eventErrorHours":           { "type": "integer", "minimum": 1 },
                "reportWarnHours":           { "type": "integer", "minimum": 1 },
                "reportErrorHours":          { "type": "integer", "minimum": 1 },
                "reportExtendedWarnHours":   { "type": "integer", "minimum": 1 },
                "reportExtendedErrorHours":  { "type": "integer", "minimum": 1 }
              }
            }
          }
        }
      }
    },

    "global": {
      "type": "object",
      "properties": {
        "imageRegistry":    { "type": "string" },
        "imagePullPolicy":  { "enum": ["Always", "IfNotPresent", "Never"] },
        "imagePullSecrets": { "type": "array", "items": { "type": "object" } },
        "storageClass":     { "type": "string" }
      }
    },

    "clickhouse": { "$ref": "#/definitions/infraDep" },
    "mariadb":    { "$ref": "#/definitions/infraDep" },
    "redis":      { "$ref": "#/definitions/infraDep" },
    "redpanda":   { "$ref": "#/definitions/infraDep" },

    "apiGateway": {
      "allOf": [
        { "$ref": "#/definitions/appService" },
        {
          "properties": {
            "authDisabled": { "type": "boolean" },
            "oidc": {
              "type": "object",
              "properties": {
                "existingSecret": { "type": "string" },
                "issuer":         { "type": "string" },
                "audience":       { "type": "string" },
                "clientId":       { "type": "string" },
                "redirectUri":    { "type": "string" }
              }
            }
          }
        }
      ]
    },

    "analyticsApi":       { "$ref": "#/definitions/appService" },
    "identityResolution": { "$ref": "#/definitions/appService" },
    "frontend":           { "$ref": "#/definitions/appService" }
  },

  "definitions": {
    "urlSecret": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "key":  { "type": "string", "minLength": 1 }
      }
    },
    "urlSecretBlock": {
      "type": "object",
      "required": ["urlSecret"],
      "properties": {
        "urlSecret": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "key":  { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "infraDep": {
      "type": "object",
      "properties": {
        "deploy":   { "type": "boolean" },
        "host":     { "type": "string" },
        "port":     { "type": "integer", "minimum": 1, "maximum": 65535 },
        "database": { "type": "string" },
        "username": { "type": "string" },
        "passwordSecret": {
          "type": "object",
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "key":  { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "appService": {
      "type": "object",
      "properties": {
        "replicaCount":  { "type": "integer", "minimum": 0 },
        "image": {
          "type": "object",
          "required": ["repository", "tag"],
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag":        { "type": "string" },
            "pullPolicy": { "enum": ["Always", "IfNotPresent", "Never"] }
          }
        },
        "resources": { "type": "object" }
      }
    }
  }
}
